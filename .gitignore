# Build trees
build/
build-*/

# Packaged distributions
dist-*/
dist-*.zip

# Cross-build dependency cache (recreated by scripts/build-win64-deps.sh)
win64-deps/

# Runtime state
imgui.ini
*.log

# Per-user runtime data — NEVER commit: these hold real people's face
