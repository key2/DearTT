# Build trees
build/
build-*/

# Packaged distributions
dist-*/
dist-*.zip

# Cross-build dependency cache (recreated by scripts/build-win64-deps.sh)
win64-deps/

# Runtime state
imgui.ini
*.log

# Per-user runtime data — NEVER commit: these hold real people's face
# embeddings (biometric data) and the operator's stream targets. Created at
# runtime; the packagers ship an empty profiles/ folder.
gallery/
profiles/

# Voxtral speech-to-text GGUF weights (~2.7 GB) — too large for git; fetch
# with third_party/voxtral/tools/download_model.sh into models/voxtral/.
models/voxtral/
*.gguf
